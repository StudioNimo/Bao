# Example environment variables for `bao`. Copy to `.env` and adjust locally
# (`.env` is gitignored). Values here are placeholders — do not put real secrets in this file.

# --- Commit message editor (order: BAO_EDITOR, then EDITOR, then VISUAL) ---
#BAO_EDITOR=vim
#EDITOR=vim
#VISUAL=vim

# Skip opening an editor when set to a truthy value: 1, true, TRUE, yes, YES (e.g. CI)
#BAO_NO_EDITOR=1

# --- `bao run` with provider: openai (ignored for `--dry-run`) ---
#OPENAI_API_KEY=
